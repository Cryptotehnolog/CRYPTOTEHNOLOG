# ==================== CRYPTOTEHNOLOG Environment Variables ====================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ==================== Project Settings ====================
PROJECT_NAME=CRYPTOTEHNOLOG
PROJECT_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ==================== Database Settings ====================
# PostgreSQL + TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=bot_password_dev
POSTGRES_DB=trading_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== Secrets Management ====================
# Infisical
INFISICAL_TOKEN=
INFISICAL_ADDRESS=https://vault.infisical.com
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev

# Legacy Vault (if using)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-only-token

# ==================== Exchange API Keys ====================
# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ==================== Risk Parameters ====================
# Base Risk Percentage (e.g., 0.01 for 1%)
BASE_R_PERCENT=0.01

# Maximum R per trade
MAX_R_PER_TRADE=1.0

# Maximum portfolio R exposure
MAX_PORTFOLIO_R=5.0

# Maximum position size (USD)
MAX_POSITION_SIZE=10000

# ==================== Trading Settings ====================
# Default leverage
DEFAULT_LEVERAGE=1

# Maximum leverage
MAX_LEVERAGE=10

# Order timeout (seconds)
ORDER_TIMEOUT=30

# Slippage tolerance (percentage)
SLIPPAGE_TOLERANCE=0.001

# ==================== Observability ====================
# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (JSON, TEXT)
LOG_FORMAT=JSON

# Metrics enabled
METRICS_ENABLED=true

# Prometheus port
PROMETHEUS_PORT=9090

# ==================== Web Dashboard ====================
# Dashboard enabled
DASHBOARD_ENABLED=true

# Dashboard host
DASHBOARD_HOST=0.0.0.0

# Dashboard port
DASHBOARD_PORT=8000

# ==================== Event Bus ====================
# Event bus type (REDIS, ZEROMQ)
EVENT_BUS_TYPE=REDIS

# ZeroMQ ports (if using)
ZEROMQ_PUB_PORT=5555
ZEROMQ_SUB_PORT=5556

# ==================== Rate Limiting ====================
# Exchange API rate limit (requests per second)
EXCHANGE_RATE_LIMIT=10

# WebSocket rate limit
WS_RATE_LIMIT=100

# ==================== Circuit Breaker ====================
# Circuit breaker enabled
CIRCUIT_BREAKER_ENABLED=true

# Failure threshold
FAILURE_THRESHOLD=5

# Recovery timeout (seconds)
RECOVERY_TIMEOUT=60

# ==================== Kill Switch ====================
# Kill switch enabled
KILL_SWITCH_ENABLED=true

# Emergency stop on critical error
EMERGENCY_STOP_ON_CRITICAL=true

# ==================== Development Settings ====================
# Hot reload enabled
HOT_RELOAD=true

# Profiling enabled
PROFILING_ENABLED=false

# Debug mode
DEBUG_MODE=true

# ==================== Notification Settings ====================
# Telegram bot token (optional)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (optional)
TELEGRAM_CHAT_ID=

# Email notifications (optional)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_TO=

# ==================== Feature Flags ====================
# Feature flags for experimental features
FEATURE_EXCHANGE_MONITORING=true
FEATURE_FUNDING_RATE_ARBITRAGE=false
FEATURE_SHADOW_MODE=false
FEATURE_STRESS_TESTING=false

# ==================== Advanced Settings ====================
# Thread pool size
THREAD_POOL_SIZE=4

# Async task queue size
ASYNC_QUEUE_SIZE=1000

# Connection pool size
CONNECTION_POOL_SIZE=10

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ==================== Security ====================
# Encryption key (for sensitive data at rest)
ENCRYPTION_KEY=

# JWT secret (for API authentication)
JWT_SECRET=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
